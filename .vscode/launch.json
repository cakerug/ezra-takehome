{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "backend",
      "type": "node-terminal",
      "request": "launch",
      "command": "dotnet run --urls http://localhost:5265",
      "cwd": "${workspaceFolder}/backend/TodoApi"
    },
    {
      "name": "frontend-dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "backend-tests",
      "type": "node-terminal",
      "request": "launch",
      "command": "dotnet test",
      "cwd": "${workspaceFolder}/backend/TodoApi.Tests"
    },
    {
      "name": "frontend-tests",
      "type": "node-terminal",
      "request": "launch",
      "command": "npx vitest",
      "cwd": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "backend + frontend",
      "configurations": ["backend", "frontend-dev"]
    }
  ]
}
